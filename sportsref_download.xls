<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>
    
    

   
   <thead>      
      <tr>
         <th aria-label="Tm" data-stat="team_name" scope="col" class=" poptip sort_default_asc left">Tm</th>
         <th aria-label="#Murciélago" data-stat="batters_used" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Number of Players used in Games&lt;/strong&gt;">#Murciélago</th>
         <th aria-label="Edad de murciélago" data-stat="age_bat" scope="col" class=" poptip sort_default_asc center" data-tip="&lt;strong&gt;Batters&amp;#x2019; average age&lt;/strong&gt;&lt;br&gt;Weighted by AB + Games Played">Edad de murciélago</th>
         <th aria-label="Carreras anotadas por partido" data-stat="runs_per_game" scope="col" class=" poptip center" data-tip="Runs Scored Per Game">R/G</th>
         <th aria-label="Juegos jugados" data-stat="G" scope="col" class=" poptip center" data-tip="Games Played or Pitched">GRAMO</th>
         <th aria-label="Apariencia de la placa" data-stat="PA" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Plate Appearances&lt;/strong&gt;&lt;br&gt;When available, we use actual plate appearances from play-by-play game accounts&lt;br&gt;Otherwise estimated using AB + BB + HBP + SF + SH,&lt;br&gt;which excludes catcher interferences.&lt;br&gt;When &lt;span class=tooltip&gt;this color&lt;/span&gt; click for a summary of each PA.">Pensilvania</th>
         <th aria-label="Al bate" data-stat="AB" scope="col" class=" poptip center" data-tip="At Bats">AB</th>
         <th aria-label="Carreras anotadas" data-stat="R" scope="col" class=" poptip center" data-tip="Runs Scored/Allowed">R</th>
         <th aria-label="Éxitos" data-stat="H" scope="col" class=" poptip center" data-tip="Hits/Hits Allowed">H</th>
         <th aria-label="Dobles" data-stat="2B" scope="col" class=" poptip center" data-tip="Doubles Hit/Allowed">2B</th>
         <th aria-label="Triples" data-stat="3B" scope="col" class=" poptip center" data-tip="Triples Hit/Allowed">3B</th>
         <th aria-label="Jonrones" data-stat="HR" scope="col" class=" poptip center" data-tip="Home Runs Hit/Allowed">HORA</th>
         <th aria-label="Carreras impulsadas" data-stat="RBI" scope="col" class=" poptip center" data-tip="Runs Batted In">RBI</th>
         <th aria-label="Bases robadas" data-stat="SB" scope="col" class=" poptip center" data-tip="Stolen Bases">SB</th>
         <th aria-label="Atrapado robando" data-stat="CS" scope="col" class=" poptip center" data-tip="Caught Stealing">CS</th>
         <th aria-label="Bases por bolas" data-stat="BB" scope="col" class=" poptip center" data-tip="Bases on Balls/Walks">CAMA Y DESAYUNO</th>
         <th aria-label="ponches" data-stat="SO" scope="col" class=" poptip center" data-tip="Strikeouts">ENTONCES</th>
         <th aria-label="Promedio de bateo" data-stat="batting_avg" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;Hits/At Bats&lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played&lt;br&gt;Bold indicates either highest BA using current stats&lt;br&gt;or awarded title at end of year." data-filter="1" data-name="Batting Average">licenciado en Letras</th>
         <th aria-label="% en base" data-stat="onbase_perc" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;(H + BB + HBP)/(At Bats + BB + HBP + SF)&lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played" data-filter="1" data-name="On-Base%">OBP</th>
         <th aria-label="% de slugging" data-stat="slugging_perc" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;Total Bases/At Bats or &lt;br&gt;(1B + 2*2B + 3*3B + 4*HR)/AB&lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played" data-filter="1" data-name="Slugging %">SLG</th>
         <th aria-label="Bases en base más slugging" data-stat="onbase_plus_slugging" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;On-Base + Slugging Percentages &lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played" data-filter="1" data-name="On-Base Plus Slugging">Operaciones</th>
         <th aria-label="OPS+ ajustado" data-stat="onbase_plus_slugging_plus" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;OPS+&lt;/strong&gt;&lt;br&gt;100*[OBP/lg OBP + SLG/lg SLG - 1]&lt;br&gt;Adjusted to the player&amp;#x2019;s ballpark(s)">OPS+</th>
         <th aria-label="Bases totales" data-stat="TB" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Total Bases&lt;/strong&gt;&lt;br&gt;Singles + 2 x Doubles + 3 x Triples + 4 x Home Runs.">tuberculosis</th>
         <th aria-label="Dobles jugadas aterrizadas en" data-stat="GIDP" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Double Plays Grounded Into&lt;/strong&gt;&lt;br&gt;Only includes standard 6-4-3, 4-3, etc. double plays.&lt;br&gt;First tracked in 1933.&lt;br&gt;For gamelogs only in seasons we have play-by-play, we include triple plays as well.&lt;br&gt;All official seasonal totals do not include GITP's.">PIB</th>
         <th aria-label="Golpeado por un lanzamiento" data-stat="HBP" scope="col" class=" poptip center" data-tip="Times Hit by a Pitch.">HBP</th>
         <th aria-label="Golpes de sacrificio" data-stat="SH" scope="col" class=" poptip center" data-tip="Sacrifice Hits (Sacrifice Bunts)">SH</th>
         <th aria-label="Moscas de sacrificio" data-stat="SF" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Sacrifice Flies&lt;/strong&gt;&lt;br&gt;First tracked in 1954.">SF</th>
         <th aria-label="Bases intencionales por bolas" data-stat="IBB" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Intentional Bases on Balls&lt;/strong&gt;&lt;br&gt;First tracked in 1955.">IBB</th>
         <th aria-label="Corredores que quedan en base" data-stat="LOB" scope="col" class=" poptip center" data-tip="Runners Left On Base">LOB</th>
      </tr>
      </thead>
